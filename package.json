{
	"name": "rr-starter",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3000",
		"preview": "vite preview",
		"build:storybook": "storybook build -o build-storybook",
		"dev:storybook": "storybook dev -p 6006",
		"format": "prettier . --write",
		"lint": "eslint . --fix && stylelint '**/*.css' --fix",
		"lint:ts": "eslint . --fix",
		"lint:css": "stylelint '**/*.css' --fix",
		"typecheck": "tsr generate && tsc",
		"prepare": "husky || true",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:vr": "npm run build:storybook && npx playwright test",
		"test:vr:update": "npm run build:storybook && npx playwright test --update-snapshots"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.css": [
			"prettier --write",
			"stylelint --fix"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@t3-oss/env-core": "^0.13.11",
		"@tanstack/react-devtools": "^0.10.2",
		"@tanstack/react-query": "^5.99.2",
		"@tanstack/react-query-devtools": "^5.99.2",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"clsx": "^2.1.1",
		"modern-normalize": "^3.0.1",
		"nitro": "npm:nitro-nightly@latest",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^9.39.4",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@playwright/test": "^1.59.1",
		"@storybook/react": "^10.3.5",
		"@storybook/react-vite": "^10.3.5",
		"@tanstack/devtools-vite": "latest",
		"@tanstack/eslint-plugin-router": "^1.161.6",
		"@tanstack/router-cli": "^1.166.33",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"@types/node": "^22",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^9.39.4",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-testing-library": "^7.16.2",
		"globals": "^17.5.0",
		"http-server": "^14.1.1",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"jsdom": "^29.0.2",
		"lint-staged": "^16.4.0",
		"msw": "^2.13.4",
		"prettier": "^3.8.3",
		"storybook": "^10.3.5",
		"stylelint": "^17.0.0",
		"stylelint-config-css-modules": "^4.6.0",
		"stylelint-config-recess-order": "^7.7.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-order": "^8.1.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.4",
		"vitest-axe": "^0.1.0"
	}
}
